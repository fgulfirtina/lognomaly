@using LogNomaly.Web.Entities.Models
@using LogNomaly.Web.ViewModels
@model XaiViewModel
@{
	ViewData["Title"] = "Log Details";
	var r = Model.Result!;
	var score = (r.FinalRiskScore * 100).ToString("F0");
	var shortId = Model.SessionId?.Substring(0, Math.Min(Model.SessionId.Length, 8)) ?? "Unknown";
}

<div style="margin-bottom: 24px;">
	<a href="javascript:history.back()" style="text-decoration:none; color:var(--text-muted); font-size:13px;">
		← Back to Logs / <span style="color:var(--text-primary)">Log #@shortId</span>
	</a>
</div>

<div class="page-header" style="margin-bottom: 20px;">
	<div style="display:flex; align-items:center; gap:12px;">
		<h1 class="page-title" style="margin:0;">Log ID: #@shortId</h1>
		<span class="risk-badge @r.RiskLevel" style="font-size:10px; padding:4px 10px;">@r.RiskLevel.ToUpper() THREAT</span>
	</div>
	<div class="live-badge" style="background:var(--bg-page); font-weight:500;">
		Score: @score/100
	</div>
</div>

<div class="card" style="background:#1a1a1a; border:none; padding:0; overflow:hidden;">
	<div style="padding:10px 20px; background:#252525; display:flex; justify-content:space-between; align-items:center;">
		<div style="display:flex; align-items:center; gap:12px;">
			<span style="font-family:var(--font-mono); font-size:10px; color:#aaa; text-transform:uppercase;">Raw Log Payload</span>
			@if (r.ExtractedHour != -1)
			{
				<span style="font-size:10px; background:rgba(59, 130, 246, 0.2); color:#60a5fa; border: 1px solid #3b82f6; padding:2px 8px; border-radius:12px;">
					🕒 Time Context: @(r.ExtractedHour.ToString("00")):00
				</span>
			}
		</div>
		<span id="copyBtn" onclick="copyLog()" style="color:var(--accent); font-size:11px; cursor:pointer; user-select:none;">
			<span id="copyIcon">❐</span> <span id="copyText">Copy</span>
		</span>
	</div>
	<div style="padding:24px; font-family:var(--font-mono); font-size:13px; color:#4ade80; line-height:1.6;">
		<pre id="rawLog" style="margin:0; white-space: pre-wrap;">@(string.IsNullOrEmpty(r.RawLog) ? r.Message : r.RawLog)</pre>
	</div>
</div>

<div class="two-col" style="margin-top:24px;">
	<div class="card">
		<div class="card-header"><div class="card-title">💡 AI Insight</div></div>
		<div style="font-size:14px; color:var(--text-muted); line-height:1.6; margin-bottom:24px;">
			@if (r.RiskLevel == "Low")
			{
				<p>The model analyzed this log and determined it matches <strong>baseline system behavior</strong>. No suspicious patterns or signatures were found.</p>
			}
			else
			{
				<p>The AI engine identified this event as a <strong>@r.PredictedClass</strong>.</p>
				@if (r.ShapExplanation != null && r.ShapExplanation.TopFeatures != null && r.ShapExplanation.TopFeatures.Any())
				{
					var riskDrivers = r.ShapExplanation.TopFeatures.Where(f => f.ShapValue > 0).Select(f => f.Feature == "log_hour" ? "Anomalous Activity Time" : f.Feature).ToList();
					if (riskDrivers.Any())
					{
						<p style="margin-top: 8px;">
							<strong>Primary Risk Drivers:</strong>
							<span style="color:var(--text-primary)">@string.Join(", ", riskDrivers)</span>
						</p>
					}
				}
				else
				{
					<p style="margin-top: 8px;">Statistical anomalies detected in the log structure.</p>
				}
			}
		</div>
		<div class="card-subtitle" style="text-transform:uppercase; font-size:11px; margin-bottom:12px;">Recommended Actions</div>
		<div style="display:flex; flex-direction:column; gap:10px;">
			@if (r.RiskLevel == "Low")
			{
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:var(--ok)">✓</span> System operating normally. No action required.
				</div>
			}
			// +++ YENİ EKLENEN TEMPORAL ANOMALY AKSİYONLARI +++
			else if (r.PredictedClass == "TemporalAnomaly")
			{
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none; border-left:3px solid #f97316;">
					<span style="color:#f97316">🕒</span> Verify if this action was authorized outside business hours
				</div>
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:#f97316">👤</span> Check user access logs for compromised credentials
				</div>
			}
			else if (r.PredictedClass == "SystemFailure" || r.DatasetRouted == "HDFS")
			{
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:#eab308">🔧</span> Run HDFS fsck (File System Check)
				</div>
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:#eab308">💾</span> Inspect DataNode health & memory usage
				</div>
			}
			else if (r.IsKnownThreat || r.PredictedClass != "Normal")
			{
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none; border-left:3px solid var(--danger);">
					<span style="color:var(--danger)">⊘</span> Block associated IP Address immediately
				</div>
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:var(--danger)">🛡️</span> Isolate affected endpoints
				</div>
			}
			else
			{
				<div class="meta-item" style="display:flex; align-items:center; gap:10px; background:var(--bg-page); border:none;">
					<span style="color:#888">👀</span> Flag for manual analyst review
				</div>
			}
		</div>
	</div>

	<div class="card">
		<div class="card-header"><div class="card-title">Why is this Risky? (SHAP)</div></div>
		<div style="display:flex; gap:20px; font-size:10px; text-transform:uppercase; margin-bottom:24px; justify-content:center;">
			<div style="display:flex; align-items:center; gap:6px;"><div style="width:12px; height:12px; background:#3b82f6; border-radius:2px;"></div> Lowers Risk</div>
			<div style="display:flex; align-items:center; gap:6px;"><div style="width:12px; height:12px; background:#ef4444; border-radius:2px;"></div> Increases Risk</div>
		</div>
		@if (r.ShapExplanation != null && r.ShapExplanation.TopFeatures != null && r.ShapExplanation.TopFeatures.Any())
		{
			@foreach (var feat in r.ShapExplanation.TopFeatures)
			{
				var isPos = feat.ShapValue > 0;
				var barPct = Math.Min(Math.Abs(feat.ShapValue) * 400, 100);
				<div class="shap-bar-row" style="margin-bottom:18px;">
					<div class="shap-feature" style="width:100px; font-size:12px;">@feat.Feature</div>
					<div class="shap-bar-outer" style="background:#f1f5f9; height:14px; flex:1;">
						<div style="width:@barPct.ToString("F0")%; height:100%; background:@(isPos ? "#ef4444" : "#3b82f6"); border-radius:4px;"></div>
					</div>
				</div>
			}
		}
		else
		{
			<p style="font-size:12px; color:var(--text-dim); text-align:center;">No SHAP data for this risk level.</p>
		}
	</div>
</div>

<div class="card" style="margin-top:24px; display:flex; justify-content:center; align-items:center; gap:16px; background:var(--bg-page);">
	<button class="btn btn-warning" onclick="openCorrectionModal()" style="border-radius:20px; padding:10px 20px; font-weight:bold; background:#f59e0b; color:white; border:none;">⚠ Report Incorrect Prediction</button>
	<button class="btn btn-primary" onclick="startInvestigation()" style="border-radius:20px; padding:10px 30px;">🔍 Start Investigation</button>
</div>

<dialog id="correctionModal" class="native-modal">
	<form method="dialog" id="correctionForm">
		<h3>⚠ Report Incorrect Prediction</h3>

		<div class="readonly-banner" style="background: #f1f5f9; padding: 10px; border-radius: 6px; margin-bottom: 15px;">
			<small style="color:var(--text-muted)">Current AI Prediction:</small>
			<strong id="modalCurrentAiPred" style="color:var(--danger); display:block; font-size:16px;">@(Model.Result?.PredictedClass ?? "Unknown")</strong>
		</div>

		<div class="form-group" style="margin-bottom: 15px;">
			<label for="proposedLabel" style="display:block; margin-bottom:5px; font-size:13px; font-weight:bold;">Proposed Correct Label:</label>
			<select id="proposedLabel" style="width:100%; padding:8px; border-radius:4px; border:1px solid var(--border);" required onchange="updateDynamicHint()">
				<option value="">-- Select Label --</option>
				<option value="Normal">Normal</option>
				<option value="BruteForce">BruteForce</option>
				<option value="SQLInjection">SQLInjection</option>
				<option value="DDoS">DDoS</option>
				<option value="SystemFailure">SystemFailure</option>
				<option value="UnknownAnomaly">UnknownAnomaly</option>
			</select>
			<small id="dynamicHint" style="display:block; margin-top:5px; font-weight:bold;"></small>
		</div>

		<div class="form-group" style="margin-bottom: 15px;">
			<label for="analystNotes" style="display:block; margin-bottom:5px; font-size:13px; font-weight:bold;">Justification (Min 10 chars):</label>
			<textarea id="analystNotes" minlength="10" required placeholder="Explain why the AI is wrong..." style="width:100%; padding:8px; border-radius:4px; border:1px solid var(--border); min-height:80px;"></textarea>
		</div>

		<div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
			<button type="button" class="btn btn-outline" onclick="document.getElementById('correctionModal').close()">Cancel</button>
			<button type="button" class="btn btn-primary" onclick="submitCorrection()">Submit Correction</button>
		</div>
	</form>
</dialog>

@section Scripts {
	<script>
		function copyLog() {
			const logText = document.getElementById('rawLog').innerText;
			const btnText = document.getElementById('copyText');
			const btnIcon = document.getElementById('copyIcon');

			navigator.clipboard.writeText(logText).then(() => {
				btnText.innerText = "Copied!";
				btnIcon.innerText = "✓";
				setTimeout(() => {
					btnText.innerText = "Copy";
					btnIcon.innerText = "❐";
				}, 2000);
			});
		}

		function startInvestigation() {
			const notes = prompt("Vaka (Investigation) başlatılıyor. Varsa ön notlarınızı girebilirsiniz (Opsiyonel):");

			if (notes === null) return; // Kullanıcı iptale bastı, işlemi kes

			// Not girsin veya boş bıraksın fark etmez, tek bir istek atıyoruz
			sendActionToBackend("Investigate", notes);
		}

		// YENİ: Backend'e istek atarken ProposedLabel'ı da yolluyoruz
		async function sendActionToBackend(actionType, notes = "", proposedLabel = null) {
			var shortId = '@(Model.SessionId)' ? '@(Model.SessionId)'.substring(0, 8) : "Unknown";
			const logId = shortId;
			const rawLog = document.getElementById('rawLog') ? document.getElementById('rawLog').innerText.trim() : "Log bulunamadı";
			const predictedClass = "@(Model.Result?.PredictedClass ?? "Unknown")";
			const riskLevel = "@(Model.Result?.RiskLevel ?? "Low")";

			const payload = {
				LogId: logId,
				RawLog: rawLog,
				PredictedClass: predictedClass,
				RiskLevel: riskLevel,
				ActionType: actionType,
				AnalystNotes: notes,
				ProposedLabel: proposedLabel // YENİ EKLENEN VERİ
			};

			try {
				const response = await fetch('/Feedback/Submit', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload)
				});

				const data = await response.json();

				if (data.success) {
					if (actionType === 'Investigate') {
						alert("✅ Vaka başarıyla oluşturuldu! Log, Analist paneline atandı.");
					} else {
						alert("✅ Log düzeltmesi SOC Manager onayına gönderildi. Onaylandığında model yeniden eğitilecek!");
						document.getElementById('correctionModal').close();
					}
				} else {
					alert("❌ İşlem başarısız: " + data.message);
				}
			} catch (error) {
				console.error("API Bağlantı Hatası:", error);
				alert("Sunucuya ulaşılamadı. Lütfen konsolu kontrol edin.");
			}
		}

		// YENİ MODAL FONKSİYONLARI
		function openCorrectionModal() {
			document.getElementById('correctionModal').showModal();
		}

		function updateDynamicHint() {
			const aiPred = "@(Model.Result?.PredictedClass ?? "Unknown")";
			const proposed = document.getElementById('proposedLabel').value;
			const hintEl = document.getElementById('dynamicHint');

			if (!proposed) { hintEl.innerText = ""; return; }

			const isAiThreat = aiPred !== "Normal";
			const isNewThreat = proposed !== "Normal";

			if (isAiThreat && !isNewThreat) {
				hintEl.innerText = "💡 This will be logged as a False Positive.";
				hintEl.style.color = "green";
			} else if (!isAiThreat && isNewThreat) {
				hintEl.innerText = "🚨 This will be logged as a False Negative!";
				hintEl.style.color = "red";
			} else {
				hintEl.innerText = "🔄 This will be logged as a Misclassification.";
				hintEl.style.color = "orange";
			}
		}

		function submitCorrection() {
			const proposed = document.getElementById('proposedLabel').value;
			const notes = document.getElementById('analystNotes').value;

			if (!proposed) {
				alert("Please select a proposed label.");
				return;
			}
			if (!notes || notes.trim().length < 10) {
				alert("Please provide a justification (minimum 10 characters).");
				return;
			}

			if(confirm("Are you sure you want to submit this correction for model retraining?")) {
				sendActionToBackend("Correction", notes, proposed); // ActionType artık 'Correction'
			}
		}

	</script>
}