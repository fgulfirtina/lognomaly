<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogNomaly</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="mobile-topbar" style="display: none;">
        <button id="hamburger-btn" aria-label="Menu" style="background: none; border: none; font-size: 24px; color: var(--text-primary); cursor: pointer;">☰</button>
        <span class="mobile-logo" style="font-weight: 600; font-size: 18px;">LogNomaly SOC</span>
    </div>

    <div class="app-shell">
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">L</div>
                <span class="logo-text">LogNomaly</span>
            </div>
            <ul class="nav-links">
                <li>
                    <a href="/" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <span class="nav-icon">+</span> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/Home/Analyze" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Analyze" ? "active" : "")">
                        <span class="nav-icon">=</span> Log Analysis
                    </a>
                </li>
                <li>
                    <a href="/Home/SingleAnalyze" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "SingleAnalyze" ? "active" : "")">
                        <span class="nav-icon">o</span> Single Line Analysis
                    </a>
                </li>
                @if (User.IsInRole("Senior") || User.IsInRole("Admin"))
                {
                    <li style="margin-top: 15px; margin-bottom: 10px;">
                        <div style="font-size: 10px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; padding-left: 12px;">Administration</div>
                    </li>
                    <li>
                        <a href="/SocManager/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "SocManager" ? "active" : "")">
                            <span class="nav-icon">🛡️</span> SOC Manager
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a href="/Admin/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                            <span class="nav-icon">⚙️</span> Admin Panel
                        </a>
                    </li>
                }

                <li style="margin-top: 20px; padding-top: 10px; border-top: 0.5px solid var(--border);">
                    <form asp-controller="Auth" asp-action="Logout" method="post" style="margin: 0; padding: 0;">
                        <button type="submit" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 9px 12px; border-radius: var(--radius-sm); color: var(--danger); background: transparent; border: none; cursor: pointer; font-family: var(--font-sans); font-size: 13px; font-weight: 500; text-align: left; transition: all 0.15s;">
                            <span class="nav-icon" style="color: var(--danger); font-size: 14px;">⏻</span> Sign Out
                        </button>
                    </form>
                </li>
            </ul>
            <div class="api-status" id="apiStatus">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText" style="font-size:12px">Checking...</span>
            </div>
        </nav>
        <main class="main-content">
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        const hamburgerBtn = document.getElementById('hamburger-btn');
        if (hamburgerBtn) {
            hamburgerBtn.addEventListener('click', function () {
                document.getElementById('sidebar').classList.toggle('open');
            });
        }
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>