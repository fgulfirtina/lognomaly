<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogNomaly</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <nav class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">L</div>
                <span class="logo-text">LogNomaly</span>
            </div>
            <ul class="nav-links">
                <li>
                    <a href="/" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <span class="nav-icon">+</span> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/Home/Analyze" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Analyze" ? "active" : "")">
                        <span class="nav-icon">=</span> Log Analysis
                    </a>
                </li>
                <li>
                    <a href="/Home/SingleAnalyze" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "SingleAnalyze" ? "active" : "")">
                        <span class="nav-icon">o</span> Tek Satir
                    </a>
                </li>
            </ul>
            <div class="api-status" id="apiStatus">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText" style="font-size:12px">Kontrol ediliyor...</span>
            </div>
        </nav>
        <main class="main-content">
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>