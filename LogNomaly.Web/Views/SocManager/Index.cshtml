@model LogNomaly.Web.ViewModels.SocManagerViewModel
@{
    ViewData["Title"] = "SOC Management";
}

<div class="page-header" style="margin-bottom: 24px;">
    <div>
        <h1 class="page-title" style="margin:0;">SOC Management Console</h1>
        <div class="page-subtitle">Senior Analyst Workspace & Queue Management</div>
    </div>
</div>

<div class="two-col" style="grid-template-columns: 1fr;">

    <div class="card">
        <div class="card-header">
            <div class="card-title">
                🔍 Active Investigations
                <span style="background:var(--accent); color:#111; padding:2px 8px; border-radius:12px; font-size:11px; margin-left:8px;">
                    @Model.ActiveCases.Count Cases
                </span>
            </div>
        </div>

        @if (Model.ActiveCases.Any())
        {
            <div style="overflow-x: auto;">
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Case ID</th>
                            <th>Log ID</th>
                            <th>Threat Class</th>
                            <th>Assigned To</th>
                            <th>Status</th>
                            <th>Opened At</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invCase in Model.ActiveCases)
                        {
                            <tr>
                                <td style="font-family:var(--font-mono); font-weight:500;">CAS-@invCase.Id.ToString("D4")</td>
                                <td style="font-family:var(--font-mono); color:var(--text-muted);">@invCase.Feedback?.LogId</td>
                                <td>
                                    <span class="risk-badge @(invCase.Feedback?.RiskLevel ?? "Low")">
                                        @(invCase.Feedback?.PredictedClass ?? "Unknown")
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:6px;">
                                        <div style="width:20px; height:20px; background:var(--bg-page); border:1px solid var(--border); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:10px;">
                                            @(invCase.AssignedAnalyst?.Username.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <span style="font-size:12px;">@invCase.AssignedAnalyst?.Username</span>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-size:11px; font-weight:500; color:var(--warn);">@invCase.Status</span>
                                </td>
                                <td style="font-size:12px; color:var(--text-muted);">@invCase.OpenedAt.ToString("MMM dd, HH:mm")</td>
                                <td>
                                    <a href="/SocManager/Review/@invCase.FeedbackId" class="btn btn-outline btn-sm">Review Case</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">☕</div>
                <div style="font-weight:500;">No active investigations</div>
                <div style="font-size:12px; color:var(--text-dim);">The SOC queue is currently clear.</div>
            </div>
        }
    </div>

    <div class="investigation-card" style="margin-top: 30px; background: var(--bg-surface, #ffffff); border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid var(--border, #eaeaea); padding: 20px;">

        <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            <h3 style="margin: 0; font-size: 1.2rem; color: var(--text-primary);">📋 Pending Corrections Queue</h3>
            <span style="background: var(--warn, #ffc107); color: #000; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem; font-weight: bold;">@Model.PendingCorrections.Count() Cases</span>
        </div>

        <div class="table-responsive">
            <table class="clean-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border, #eaeaea); color: var(--text-muted, #888); font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-align: left;">
                        <th style="padding: 12px 8px;">Log ID</th>
                        <th style="padding: 12px 8px;">Time</th>
                        <th style="padding: 12px 8px;">Analyst</th>
                        <th style="padding: 12px 8px;">Correction Type</th>
                        <th style="padding: 12px 8px;">Label Transition</th>
                        <th style="padding: 12px 8px; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PendingCorrections)
                    {
                        // Determine the type
                        string badgeText = "Review";
                        string badgeStyle = "background-color: var(--text-muted); color: white;";

                        string aiLabel = string.IsNullOrEmpty(item.PredictedClass) ? "Unknown" : item.PredictedClass;
                        string userLabel = string.IsNullOrEmpty(item.ProposedLabel) ? "Unknown" : item.ProposedLabel;

                        // 1. FP Check
                        if (item.ActionType == "FalsePositive" || userLabel == "Normal")
                        {
                            userLabel = "Normal";
                            badgeText = "FP Claim";
                            badgeStyle = "background-color: var(--ok, #28a745); color: white;";
                        }
                        // 2. FN Check
                        else if (aiLabel == "Normal" && userLabel != "Normal" && userLabel != "Unknown")
                        {
                            badgeText = "FN Claim";
                            badgeStyle = "background-color: var(--danger, #dc3545); color: white;";
                        }
                        // 3. Misclass Check
                        else if (aiLabel != "Normal" && userLabel != "Normal" && aiLabel != userLabel)
                        {
                            badgeText = "Misclass";
                            badgeStyle = "background-color: var(--warn, #ffc107); color: black;";
                        }
                        // ---------------------------------------------------

                        <tr style="border-bottom: 1px solid var(--border, #eaeaea); transition: background 0.2s;">
                            <td style="padding: 16px 8px; font-family: monospace; color: var(--text-muted);">@item.LogId.Substring(0, Math.Min(8, item.LogId.Length))</td>
                            <td style="padding: 16px 8px; font-size: 0.9em;">@item.CreatedAt.ToString("MMM dd, HH:mm")</td>

                            <td style="padding: 16px 8px;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div style="width: 24px; height: 24px; border-radius: 50%; background: #eee; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: bold; color: #555;">
                                        @(item.Analyst?.Username?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <span>@item.Analyst?.Username</span>
                                </div>
                            </td>

                            <td style="padding: 16px 8px;">
                                <span style="padding: 4px 10px; border-radius: 6px; font-weight: 600; font-size: 0.8rem; @badgeStyle">
                                    @badgeText
                                </span>
                            </td>

                            <td style="padding: 16px 8px; font-size: 0.9em;">
                                <span style="color: var(--text-muted);">@aiLabel</span>
                                <strong style="margin: 0 5px; color: var(--text-muted);">➔</strong>
                                <span style="font-weight: 600; color: var(--text-primary);">@userLabel</span>
                            </td>

                            <td style="padding: 16px 8px; text-align: right;">
                                <a href="/SocManager/Review/@item.Id" style="display: inline-block; padding: 6px 14px; border: 1px solid var(--border, #ccc); border-radius: 6px; color: var(--text-primary); text-decoration: none; font-size: 0.85rem; background: transparent; transition: all 0.2s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='transparent'">
                                    Review Case
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.PendingCorrections.Any())
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                <i class="icon-check" style="font-size: 2rem;"></i>
                <p>No pending corrections. The queue is clear!</p>
            </div>
        }
    </div>
</div>

<dialog id="logDetailsModal" style="width: 650px; max-width: 90vw; padding: 0; border: 1px solid var(--border); border-radius: var(--radius); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); margin: auto; background: var(--bg-card); color: var(--text-primary);">
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 0.5px solid var(--border); background: var(--bg-page);">
        <div id="modalTitle" style="font-weight: 600; font-size: 16px;">Log Details</div>
        <button onclick="document.getElementById('logDetailsModal').close()" style="background:none; border:none; font-size:18px; cursor:pointer; color:var(--text-muted);">&times;</button>
    </div>
    <div style="padding: 24px;">
        <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; font-weight:500;">Raw Payload</div>
        <pre id="modalRawLog" style="background:#1a1a1a; color:#4ade80; padding:16px; border-radius:8px; font-family:var(--font-mono); font-size:13px; white-space:pre-wrap; word-wrap:break-word; max-height: 300px; overflow-y: auto; margin-bottom: 24px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);"></pre>

        <div style="display:flex; justify-content:flex-end;">
            <button class="btn btn-outline" onclick="document.getElementById('logDetailsModal').close()">Close Inspection</button>
        </div>
    </div>
</dialog>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(3px);
    }
</style>

@section Scripts {
    <script>
        async function processFeedback(feedbackId, actionType) {

            const confirmMessage = actionType === 'Approve'
                ? "Are you sure you want to approve this? It will be added to the ML retraining dataset."
                : "Are you sure you want to reject this false positive claim?";

            if (!confirm(confirmMessage)) return;

            const endpoint = actionType === 'Approve'
                ? '/SocManager/ApproveFalsePositive'
                : '/SocManager/RejectFalsePositive';

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(feedbackId) // Sending the ID directly
                });

                const data = await response.json();

                if (data.success) {
                    alert("✅ " + data.message);
                    // Refresh the page to update the queues
                    window.location.reload();
                } else {
                    alert("❌ Action failed: " + data.message);
                }
            } catch (error) {
                console.error("API Error:", error);
                alert("Could not connect to the server.");
            }
        }

        // Opens the modal
        function openLogModal(title, rawLog) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalRawLog').innerText = rawLog || "No raw payload data available for this event.";
            document.getElementById('logDetailsModal').showModal();
        }
    </script>
}